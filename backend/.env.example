PORT=5000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FRONTEND_URL=http://localhost:3000
ANTHROPIC_API_KEY=
PUPPETEER_EXECUTABLE_PATH=

# Random server-side secret used to salt SHA256 hashes of referral-visitor
# IPs. Rotate only if you're OK losing prior self-referral fraud detection.
REFERRAL_SALT=

# Shared secret between the backend and Render's Cron Jobs service.
# The daily cron hits /api/cron/approve-vested with header X-Cron-Key set
# to this value. Anything non-empty + random works.
CRON_SECRET=

# Extra lock on the /bosi/referrals fraud-review UI + its admin endpoints.
# Complements the email-based requireAdmin middleware — set it, then
# paste it into the /bosi/referrals password prompt.
ADMIN_PASSWORD=
