PORT=5000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FRONTEND_URL=http://localhost:3000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PUPPETEER_EXECUTABLE_PATH=

# Gates the LS config-check diagnostic endpoint. Set to any random value;
# admins paste it as the X-Admin-Password header to fetch the diagnostic.
ADMIN_PASSWORD=

# Job Hunter — free job board APIs
# Adzuna: 19 countries, 1k calls/mo free — https://developer.adzuna.com
# Jooble: 70+ countries, free key — https://jooble.org/api/about
# RapidAPI: shared key for JSearch (LinkedIn+Indeed+ZipRecruiter+Glassdoor)
#   and Real-Time LinkedIn Scraper. Free tier ≈ 150 req/mo combined.
#   https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
RAPIDAPI_KEY=

# PayPal Subscriptions — second payment rail alongside Lemon Squeezy.
# Mode is 'sandbox' or 'live'. Use sandbox creds while testing, then
# swap PAYPAL_CLIENT_ID/SECRET for the live app's values and flip MODE.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Webhook ID is generated by PayPal when you register the webhook URL
# in Developer Dashboard → Apps → (your app) → Webhooks. Required for
# signature verification — webhooks reject without it.
PAYPAL_WEBHOOK_ID=
# Plan IDs are produced by `node backend/scripts/paypal-pricing-setup.js create`.
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_YEARLY=
PAYPAL_PLAN_PRO_VOICE_MONTHLY=
PAYPAL_PLAN_PRO_VOICE_YEARLY=

# NOWPayments — crypto checkout rail (USDT etc). Funds are non-custodial:
# payments are forwarded straight to the payout wallet configured in the
# NOWPayments dashboard (e.g. Binance USDT TRC-20 deposit address).
# Crypto invoices are always one-shot; "monthly" / "yearly" Pro plans are
# stored as billing_interval='once' and auto-expire when the period ends.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Used as the public origin when constructing webhook callback URLs.
# Falls back to req.protocol + req.host if unset, but explicitly setting
# this in production avoids reverse-proxy edge cases.
BACKEND_URL=
